# Required in production: secret used to sign login sessions (JWT).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# If left blank, the server generates a random one on every restart (dev only —
# this logs users out and invalidates tokens each time the process restarts).
JWT_SECRET=
# Minutes before a login session expires and the user must sign in again.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: choose either OpenAI or a local Ollama instance for scripts.
OPENAI_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2

# Local dev defaults. For deployment, set DATABASE_URL to your Neon/Supabase Postgres
# connection string (e.g. postgres://user:pass@host/db?sslmode=require).
MEDIA_ROOT=./media
DATABASE_URL=sqlite:///./movie_studio.db

# Set this to your deployed frontend URL(s), comma-separated, e.g.
# https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# Optional but required for deployment on hosts without persistent disk (e.g. Render free tier):
# Cloudflare R2 (S3-compatible, free up to 10GB). Leave all blank to keep using local disk storage.
# The bucket does NOT need to be public: the backend generates short-lived presigned URLs
# on demand after checking the requesting user owns the project.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
